<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>CVC – EN Family</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@700;800;900&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
:root{--bg:#FEF9F0;--text:#2C2C54;--muted:#aaa;--green:#2BAE66;--red:#E63946;--blue:#1A78C2;--orange:#FB5607;--shadow:0 8px 0 rgba(0,0,0,0.12);}
body{font-family:'Nunito','Arial Rounded MT Bold',Arial,sans-serif;font-weight:800;background:var(--bg);height:100vh;overflow:hidden;touch-action:manipulation;}
#prog-wrap{position:fixed;top:0;left:0;width:100%;height:7px;background:rgba(0,0,0,.07);z-index:999;}
#prog-bar{height:100%;background:linear-gradient(90deg,#FF6B6B,#FFD93D,#6BCB77);transition:width .4s;width:0%;}
.screen{display:none;position:fixed;inset:0;flex-direction:column;align-items:center;justify-content:center;padding:14px 14px 86px;overflow-y:auto;animation:popIn .4s cubic-bezier(.175,.885,.32,1.275);}
.screen.active{display:flex;}
@keyframes popIn{from{transform:scale(.88);opacity:0}to{transform:scale(1);opacity:1}}
/* ══ BOTTOM TAB BAR ══ */
#tab-bar{position:fixed;bottom:0;left:0;width:100%;background:rgba(255,255,255,.97);backdrop-filter:blur(14px);border-top:2px solid #EDE8E0;z-index:998;display:flex;align-items:stretch;justify-content:space-around;padding:6px 4px 10px;gap:2px;}
.tab{border:none;background:none;flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;padding:6px 2px 4px;border-radius:14px;cursor:pointer;transition:background .18s,transform .13s;font-family:'Nunito',sans-serif;font-weight:900;}
.tab:hover{background:rgba(0,0,0,.05);}
.tab:active{transform:scale(.92);}
.tab-icon{font-size:clamp(1.2rem,3.5vw,1.6rem);line-height:1;}
.tab-label{font-size:clamp(.5rem,1.4vw,.72rem);color:#999;letter-spacing:.3px;white-space:nowrap;}
.tab.active-tab .tab-icon{filter:drop-shadow(0 2px 4px rgba(0,0,0,.18));}
.tab.active-tab .tab-label{color:var(--text);}
.tab.active-tab{background:rgba(0,0,0,.06);}
.tab-pip{width:5px;height:5px;border-radius:50%;background:transparent;margin-top:2px;transition:background .2s;}
.tab.active-tab .tab-pip{background:var(--orange);}
.big-title{font-size:clamp(1.7rem,5.5vw,3rem);color:var(--text);text-align:center;line-height:1.2;}
.sub{font-size:clamp(.82rem,2vw,1.15rem);color:var(--muted);text-align:center;margin-top:5px;}
/* ══ HOME ══ */
#s-home{background:linear-gradient(145deg,#6BCB77,#FFD93D,#FF6B6B,#4D96FF);padding:14px 14px 86px;}
.home-family{font-size:clamp(4rem,14vw,9rem);color:#fff;font-weight:900;text-shadow:0 8px 0 rgba(0,0,0,.12);animation:ibounce 1.8s ease-in-out infinite alternate;line-height:1;}
@keyframes ibounce{from{transform:translateY(0) rotate(-2deg)}to{transform:translateY(-20px) rotate(2deg)}}
.home-words{font-size:clamp(.9rem,2.5vw,1.5rem);color:rgba(255,255,255,.92);letter-spacing:5px;text-align:center;margin:8px 0 20px;}
.home-tap{font-size:clamp(1rem,2.8vw,1.6rem);color:rgba(255,255,255,.88);margin-top:18px;text-align:center;animation:ipulse 1.4s ease-in-out infinite alternate;}
@keyframes ipulse{from{opacity:.5;transform:scale(.97)}to{opacity:1;transform:scale(1.03)}}
.home-nav-hint{margin-top:14px;display:flex;align-items:center;gap:8px;background:rgba(255,255,255,.18);border-radius:50px;padding:10px 20px;}
.home-nav-hint span{font-size:.85rem;color:rgba(255,255,255,.88);font-weight:800;letter-spacing:.5px;}
/* ══ PHONICS ══ */
#s-phonics{background:var(--bg);}
.ph-grid{display:flex;flex-wrap:wrap;gap:clamp(8px,1.8vw,14px);justify-content:center;max-width:560px;margin-top:16px;}
.ph-tile{border:none;border-radius:18px;width:clamp(68px,12vw,104px);height:clamp(68px,12vw,104px);cursor:pointer;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;box-shadow:var(--shadow);transition:transform .13s,box-shadow .13s;font-family:'Nunito',sans-serif;font-weight:900;}
.ph-tile:hover{transform:translateY(-5px);box-shadow:0 13px 0 rgba(0,0,0,.12);}.ph-tile:active{transform:translateY(2px);}
.ph-ltr{font-size:clamp(1.8rem,4.2vw,2.8rem);text-shadow:0 3px 0 rgba(0,0,0,.15);}
.ph-hint{font-size:clamp(.5rem,1vw,.75rem);letter-spacing:.4px;opacity:.82;}
#zoom-ov{position:fixed;inset:0;background:rgba(0,0,0,.78);z-index:8000;display:none;align-items:center;justify-content:center;flex-direction:column;gap:14px;cursor:pointer;}
#zoom-ov.show{display:flex;}
#zoom-ltr{font-size:clamp(9rem,28vw,20rem);color:#fff;font-weight:900;font-family:'Nunito',sans-serif;text-shadow:0 12px 0 rgba(0,0,0,.22);animation:zoomPop .35s cubic-bezier(.175,.885,.32,1.275);}
@keyframes zoomPop{from{transform:scale(.2);opacity:0}to{transform:scale(1);opacity:1}}
#zoom-ex{font-size:clamp(1.3rem,4vw,2.4rem);color:rgba(255,255,255,.78);font-family:'Nunito',sans-serif;font-weight:800;letter-spacing:3px;}
#zoom-tap{font-size:clamp(.75rem,1.8vw,1.05rem);color:rgba(255,255,255,.45);font-family:'Nunito',sans-serif;margin-top:4px;}
/* ══ BLEND ══ */
#s-blend{background:var(--bg);}
.b-dots{display:flex;gap:9px;align-items:center;margin-bottom:14px;}
.b-dot{width:10px;height:10px;border-radius:50%;background:#ddd;transition:all .3s;}
.b-dot.cur{background:var(--orange);transform:scale(1.5);}.b-dot.done{background:var(--green);}
.b-card{background:#fff;border-radius:26px;padding:20px 24px;box-shadow:0 12px 0 rgba(0,0,0,.1);display:flex;flex-direction:column;align-items:center;gap:12px;max-width:430px;width:100%;}
.b-illo{width:clamp(100px,18vw,170px);height:clamp(100px,18vw,170px);display:flex;align-items:center;justify-content:center;animation:illustPop .5s cubic-bezier(.175,.885,.32,1.275);}
@keyframes illustPop{0%{transform:scale(0) rotate(-8deg)}80%{transform:scale(1.06) rotate(1deg)}100%{transform:scale(1)}}
.b-illo svg{width:100%;height:100%;}
.b-row{display:flex;align-items:center;gap:8px;font-size:clamp(2rem,6vw,3.8rem);font-weight:900;}
.b-con{border-radius:12px;padding:3px 13px;transition:all .5s cubic-bezier(.175,.885,.32,1.275);}
.b-fam{color:#8338EC;background:#F3EAFF;border-radius:12px;padding:3px 13px;transition:all .5s;}
.b-plus,.b-arrow{color:#ccc;font-size:clamp(1.1rem,2.8vw,2rem);}
.b-res{font-size:clamp(2.4rem,7vw,4.5rem);color:var(--text);opacity:0;transform:scale(.5);transition:all .55s cubic-bezier(.175,.885,.32,1.275);}
.b-res.show{opacity:1;transform:scale(1);}
.b-lbl{font-size:clamp(.88rem,2vw,1.25rem);color:var(--muted);letter-spacing:2px;text-align:center;}
.blend-btn{border:none;border-radius:50px;padding:11px 32px;background:linear-gradient(135deg,var(--blue),#5BA3E8);color:#fff;font-family:'Nunito',sans-serif;font-weight:900;font-size:clamp(.9rem,2vw,1.3rem);cursor:pointer;box-shadow:0 6px 0 #1056a0;transition:transform .13s;}
.blend-btn:hover{transform:translateY(-3px);}.blend-btn:active{transform:translateY(2px);}
.blend-skip{border:none;background:none;color:var(--muted);font-family:'Nunito',sans-serif;font-weight:800;font-size:.88rem;cursor:pointer;text-decoration:underline;}
/* ══ MATCH ══ */
#s-match{background:var(--bg);}
.match-wrap{display:grid;grid-template-columns:1fr 1fr;gap:10px;width:100%;max-width:500px;margin-top:12px;}
.match-pics,.match-words{display:flex;flex-direction:column;gap:8px;}
.m-pic{background:#fff;border-radius:16px;height:clamp(66px,11vw,88px);cursor:pointer;display:flex;align-items:center;justify-content:center;padding:4px;box-shadow:0 5px 0 rgba(0,0,0,.08);border:3px solid transparent;transition:all .15s;}
.m-pic:hover{transform:translateY(-3px);}
.m-pic.selected{border-color:var(--blue);box-shadow:0 0 0 5px rgba(26,120,194,.18),0 5px 0 var(--blue);}
.m-pic.matched{border-color:var(--green);background:#EAFFF5;pointer-events:none;opacity:.6;}
.m-pic svg{height:100%;width:auto;max-width:100%;}
.m-word{background:#fff;border-radius:16px;height:clamp(66px,11vw,88px);cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 5px 0 rgba(0,0,0,.08);border:3px solid transparent;font-size:clamp(1.6rem,4.2vw,2.4rem);color:var(--text);transition:all .15s;}
.m-word:hover{transform:translateY(-3px);}
.m-word.matched{border-color:var(--green);background:#EAFFF5;pointer-events:none;opacity:.6;}
.m-word.ws,.m-pic.ws{animation:shake .4s ease;}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-8px)}75%{transform:translateX(8px)}}
.match-score{font-size:clamp(.88rem,2vw,1.25rem);color:var(--muted);margin-top:8px;}
/* ══ SPELL ══ */
#s-spell{background:var(--bg);}
.sp-dots{display:flex;gap:7px;margin-bottom:8px;}
.sp-dot{width:10px;height:10px;border-radius:50%;background:#ddd;transition:all .3s;}
.sp-dot.cur{background:var(--orange);transform:scale(1.4);}.sp-dot.done{background:var(--green);}
.sp-illo{width:clamp(88px,16vw,145px);height:clamp(88px,16vw,145px);display:flex;align-items:center;justify-content:center;margin-bottom:4px;}
.sp-illo svg{width:100%;height:100%;}
.sp-lbl{font-size:clamp(.95rem,2.2vw,1.3rem);color:var(--muted);letter-spacing:5px;margin-bottom:12px;}
.sp-boxes{display:flex;gap:clamp(6px,1.5vw,11px);margin-bottom:14px;}
.sp-box{width:clamp(54px,10.5vw,76px);height:clamp(58px,12vw,80px);background:#fff;border-radius:16px;border:3px solid #DDD;box-shadow:0 5px 0 rgba(0,0,0,.08);display:flex;align-items:center;justify-content:center;font-size:clamp(1.8rem,4.8vw,2.8rem);color:var(--text);font-weight:900;transition:all .2s;}
.sp-box.ab{border-color:var(--blue);box-shadow:0 0 0 5px rgba(26,120,194,.18),0 5px 0 var(--blue);}
.sp-box.fb{border-color:#ccc;background:#F8F8F8;}
.sp-box.ob{border-color:var(--green);background:#EAFFF5;animation:okPop .45s ease;}
.sp-box.eb{border-color:var(--red);animation:shake .4s ease;}
@keyframes okPop{0%{transform:scale(1)}50%{transform:scale(1.2)}100%{transform:scale(1)}}
.sp-tiles{display:flex;flex-wrap:wrap;gap:clamp(6px,1.5vw,11px);justify-content:center;max-width:360px;}
.sp-tile{border:none;border-radius:14px;width:clamp(46px,9vw,64px);height:clamp(46px,9vw,64px);cursor:pointer;font-family:'Nunito',sans-serif;font-weight:900;font-size:clamp(1.25rem,3vw,1.8rem);background:#6B7280;color:#fff;box-shadow:0 6px 0 #4B5563;transition:transform .13s,box-shadow .13s,opacity .13s;}
.sp-tile:hover{transform:translateY(-4px);box-shadow:0 10px 0 #4B5563;}.sp-tile:active{transform:translateY(2px);}
.sp-tile.used{opacity:.22;pointer-events:none;transform:none;box-shadow:none;}
.sp-fb{font-size:clamp(1rem,2.5vw,1.7rem);min-height:36px;text-align:center;margin-top:4px;}
.sp-clear{border:none;background:#EEE;border-radius:50px;padding:7px 20px;font-family:'Nunito',sans-serif;font-weight:800;font-size:.88rem;color:#888;cursor:pointer;margin-top:4px;}
.sp-clear:hover{background:#FFE4CC;}
/* ══ FLASHCARD ══ */
#s-flash{background:var(--bg);}
/* Mode toggle */
.fl-mode-toggle{display:flex;background:#EDE8E0;border-radius:50px;padding:4px;gap:4px;margin-bottom:14px;}
.fl-mode-btn{border:none;border-radius:46px;padding:8px 18px;font-family:'Nunito',sans-serif;font-weight:900;font-size:clamp(.75rem,1.8vw,1rem);cursor:pointer;color:#999;background:transparent;transition:all .22s;white-space:nowrap;}
.fl-mode-btn.active-mode{background:#fff;color:var(--text);box-shadow:0 3px 8px rgba(0,0,0,.12);}
/* Progress dots */
.fl-dots{display:flex;gap:7px;margin-bottom:10px;}
.fl-dot{width:10px;height:10px;border-radius:50%;background:#ddd;transition:all .3s;}
.fl-dot.cur{background:var(--blue);transform:scale(1.4);}.fl-dot.done{background:var(--green);}
/* Card */
.flashcard{width:clamp(220px,52vw,330px);height:clamp(230px,44vw,310px);cursor:pointer;perspective:900px;position:relative;}
.fc-inner{width:100%;height:100%;position:relative;transform-style:preserve-3d;transition:transform .55s cubic-bezier(.4,0,.2,1);}
.fc-inner.flipped{transform:rotateY(180deg);}
.fc-front,.fc-back{position:absolute;inset:0;border-radius:28px;backface-visibility:hidden;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;box-shadow:0 14px 0 rgba(0,0,0,.1);}
.fc-front{background:#fff;}.fc-back{background:#fff;transform:rotateY(180deg);}
.fc-pic{display:flex;align-items:center;justify-content:center;}
.fc-pic svg{width:clamp(90px,18vw,155px);height:clamp(90px,18vw,155px);}
.fc-tap{font-size:clamp(.7rem,1.5vw,.9rem);color:var(--muted);letter-spacing:.8px;}
.fc-word{font-size:clamp(3.2rem,10vw,6rem);font-weight:900;letter-spacing:2px;}
.fc-word-hint{font-size:clamp(.8rem,1.8vw,1.1rem);color:var(--muted);letter-spacing:3px;}
/* Nav */
.fl-nav{display:flex;gap:12px;margin-top:12px;align-items:center;}
.fl-nav-btn{border:none;border-radius:50px;padding:10px 26px;font-family:'Nunito',sans-serif;font-weight:900;font-size:clamp(.88rem,2vw,1.15rem);cursor:pointer;color:#fff;box-shadow:0 5px 0 rgba(0,0,0,.14);transition:transform .13s;}
.fl-nav-btn:hover{transform:translateY(-3px);}
.fl-prev{background:#bbb;box-shadow:0 5px 0 #999;}
.fl-next{background:linear-gradient(135deg,var(--blue),#5BA3E8);box-shadow:0 5px 0 #1056a0;}
.fl-count{font-size:clamp(.82rem,1.8vw,1rem);color:var(--muted);font-weight:800;}
/* ══ LIGHTNING ══ */
#s-lightning{background:var(--bg);}
.lr-header{display:flex;align-items:center;justify-content:space-between;width:100%;max-width:460px;margin-bottom:8px;}
.lr-score-txt{font-size:clamp(1rem,2.5vw,1.4rem);color:var(--text);}
.lr-timer-wrap{background:#EEE;border-radius:50px;width:120px;height:12px;overflow:hidden;}
.lr-timer-bar{height:100%;background:linear-gradient(90deg,#6BCB77,#FFD93D,#E63946);border-radius:50px;transition:width .1s linear;width:100%;}
.lr-card{background:#fff;border-radius:26px;padding:18px 22px;box-shadow:0 12px 0 rgba(0,0,0,.1);display:flex;flex-direction:column;align-items:center;gap:12px;max-width:420px;width:100%;margin-bottom:10px;}
.lr-illo{width:clamp(85px,17vw,150px);height:clamp(85px,17vw,150px);display:flex;align-items:center;justify-content:center;}
.lr-illo svg{width:100%;height:100%;}
.lr-choices{display:flex;gap:10px;flex-wrap:wrap;justify-content:center;}
.lr-btn{border:none;border-radius:16px;padding:11px 20px;font-family:'Nunito',sans-serif;font-weight:900;font-size:clamp(1.2rem,3.2vw,1.9rem);cursor:pointer;background:#fff;border:3px solid #DDD;color:var(--text);box-shadow:0 5px 0 rgba(0,0,0,.08);transition:transform .13s;}
.lr-btn:hover{transform:translateY(-4px);}
.lr-btn.correct-lr{border-color:var(--green);background:#EAFFF5;animation:okPop .4s ease;}
.lr-btn.wrong-lr{border-color:var(--red);background:#FFF0F0;animation:shake .4s ease;}
@keyframes okPop{0%{transform:scale(1)}50%{transform:scale(1.2)}100%{transform:scale(1)}}
.lr-feedback{font-size:clamp(1.1rem,3vw,1.8rem);min-height:36px;text-align:center;}
.lr-qnum{font-size:clamp(.8rem,1.8vw,1rem);color:var(--muted);margin-bottom:4px;}
.lr-result{display:flex;flex-direction:column;align-items:center;gap:10px;text-align:center;width:100%;max-width:380px;}
.lr-result-big{font-size:clamp(2.5rem,8vw,5rem);font-weight:900;color:var(--text);}
.lr-result-msg{font-size:clamp(1rem,2.8vw,1.6rem);color:var(--muted);}
.lr-play-again{border:none;border-radius:50px;padding:12px 34px;font-family:'Nunito',sans-serif;font-weight:900;font-size:clamp(.95rem,2.3vw,1.35rem);color:#fff;background:linear-gradient(135deg,#FF6B6B,#FF8E53);box-shadow:0 6px 0 #c9472e;cursor:pointer;transition:transform .13s;}
.lr-play-again:hover{transform:translateY(-3px);}
/* ══ DONE ══ */
#s-done{background:linear-gradient(145deg,#6BCB77,#FFD93D,#4D96FF);}
.cel-ico{font-size:clamp(4rem,13vw,8rem);animation:ibounce 1.6s ease-in-out infinite alternate;}
.cel-title{font-size:clamp(2rem,6.5vw,4.5rem);color:#fff;text-shadow:0 6px 0 rgba(0,0,0,.12);text-align:center;margin-top:8px;}
.cel-sub{font-size:clamp(1rem,2.6vw,1.6rem);color:rgba(255,255,255,.9);text-align:center;margin-top:6px;}
.cel-stars{font-size:clamp(1.6rem,4.5vw,3rem);margin-top:8px;letter-spacing:4px;}
.cel-home{margin-top:24px;border:none;border-radius:50px;padding:14px 44px;font-family:'Nunito',sans-serif;font-weight:900;font-size:clamp(1.05rem,2.6vw,1.6rem);color:var(--text);background:#fff;box-shadow:0 8px 0 rgba(0,0,0,.12);cursor:pointer;transition:transform .14s;}
.cel-home:hover{transform:translateY(-4px);}
/* ══ SHARED ══ */
.toast{position:fixed;top:22px;left:50%;transform:translateX(-50%) translateY(-18px);background:#FF6B6B;color:#fff;padding:11px 30px;border-radius:50px;font-size:1.1rem;font-family:'Nunito',sans-serif;font-weight:900;z-index:9999;opacity:0;transition:all .28s;pointer-events:none;}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
.sparkle{position:fixed;pointer-events:none;z-index:9999;font-size:1.8rem;animation:spFly .9s ease forwards;}
@keyframes spFly{0%{opacity:1;transform:scale(.5) translateY(0)}100%{opacity:0;transform:scale(1.8) translateY(-80px)}}
.conf-p{position:fixed;width:11px;height:11px;border-radius:3px;opacity:0;pointer-events:none;z-index:9999;animation:confFall 1.4s ease forwards;}
@keyframes confFall{0%{opacity:1;transform:translateY(0) rotate(0)}100%{opacity:0;transform:translateY(100vh) rotate(720deg)}}
</style>
</head>
<body>
<div id="zoom-ov" onclick="closeZoom()"><div id="zoom-ltr"></div><div id="zoom-ex"></div><div id="zoom-tap">Tap anywhere to close</div></div>
<div id="prog-wrap"><div id="prog-bar"></div></div>
<div class="toast" id="toast"></div>

<!-- HOME -->
<div class="screen active" id="s-home">
  <div class="home-family">EN</div>
  <div class="home-words">hen · den · ten · pen · men · ben</div>
  <div class="home-tap">👆 Tap a section below to start!</div>
  <div class="home-nav-hint">
    <span>👂 Sounds</span><span>·</span>
    <span>📖 Read</span><span>·</span>
    <span>🎯 Match</span><span>·</span>
    <span>✏️ Spell</span><span>·</span>
    <span>🃏 Cards</span><span>·</span>
    <span>⚡ Lightning</span>
  </div>
</div>

<!-- PHONICS (accessed via sequential flow) -->
<div class="screen" id="s-phonics">
  <div class="big-title">Tap each sound!</div>
  <div class="sub">Tap a letter to see it big — say it aloud!</div>
  <div class="ph-grid" id="ph-grid"></div>
</div>

<!-- BLEND & READ -->
<div class="screen" id="s-blend">
  <div class="big-title">Blend &amp; Read!</div>
  <div class="sub">Watch the sounds come together!</div>
  <div class="b-dots" id="b-dots"></div>
  <div class="b-card">
    <div class="b-illo" id="b-illo"></div>
    <div class="b-row">
      <div class="b-con" id="b-con">p</div>
      <div class="b-plus">+</div>
      <div class="b-fam" id="b-fam">an</div>
      <div class="b-arrow">→</div>
      <div class="b-res" id="b-res">pan</div>
    </div>
    <div class="b-lbl" id="b-lbl">p + an = ?</div>
    <button class="blend-btn" id="blend-btn" onclick="doBlend()">Blend it!</button>
    <button class="blend-skip" id="blend-skip" onclick="nextBlend()">Next word ▶</button>
  </div>
</div>

<!-- MATCH -->
<div class="screen" id="s-match">
  <div class="big-title">Match it!</div>
  <div class="sub">Tap a picture · then tap its word</div>
  <div class="match-wrap"><div class="match-pics" id="match-pics"></div><div class="match-words" id="match-words"></div></div>
  <div class="match-score" id="match-score">0 / 6 matched</div>
</div>

<!-- SPELL -->
