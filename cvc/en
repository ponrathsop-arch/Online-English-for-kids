const WORDS = [
  {word:'hen',consonant:'h',color:'#E63946'},
  {word:'den',consonant:'d',color:'#FB5607'},
  {word:'ten',consonant:'t',color:'#1A78C2'},
  {word:'pen',consonant:'p',color:'#8338EC'},
  {word:'men',consonant:'m',color:'#2BAE66'},
  {word:'ben',consonant:'b',color:'#E91E8C'},
];

const PHONICS=[
  {letter:'h',hint:'hen',bg:'#E63946',dark:false,example:'h — hen'},
  {letter:'d',hint:'den',bg:'#FB5607',dark:false,example:'d — den'},
  {letter:'t',hint:'ten',bg:'#1A78C2',dark:false,example:'t — ten'},
  {letter:'p',hint:'pen',bg:'#8338EC',dark:false,example:'p — pen'},
  {letter:'m',hint:'men',bg:'#2BAE66',dark:false,example:'m — men'},
  {letter:'b',hint:'ben',bg:'#E91E8C',dark:false,example:'b — ben'},
  {letter:'e',hint:'vowel',bg:'#F5C800',dark:true,example:'e — short e sound'},
  {letter:'n',hint:'ending',bg:'#555',dark:false,example:'n — end sound'},
  {letter:'en',hint:'family',bg:'linear-gradient(135deg,#F5C800,#8338EC)',dark:false,example:'__en — the family!'},
];
const DISTRACTORS=['a','g','i','k','l','o','u','c','f','j','r','s','v','w'];

// ═══════════════════════════ SCREEN ENGINE ═══════════════════════════
const SCREEN_ORDER=['s-home','s-phonics','s-blend','s-match','s-spell','s-flash','s-lightning','s-done'];
let curIdx=0;

function showScreen(id){
  const idx=SCREEN_ORDER.indexOf(id);
  if(idx>=0) curIdx=idx;
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  document.getElementById('prog-bar').style.width=(curIdx/(SCREEN_ORDER.length-1)*100)+'%';
  // Update tab bar active state
  const tabMap={
    's-home':'tab-home','s-phonics':'tab-sounds','s-blend':'tab-blend',
    's-match':'tab-match','s-spell':'tab-spell','s-flash':'tab-flash',
    's-lightning':'tab-lightning','s-done':'tab-lightning'
  };
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active-tab'));
  const activeTab=tabMap[id];
  if(activeTab) document.getElementById(activeTab)?.classList.add('active-tab');
  if(id==='s-phonics') initPhonics();
  if(id==='s-blend') initBlend();
  if(id==='s-match') initMatch();
  if(id==='s-spell') initSpell();
  if(id==='s-flash') initFlash();
  if(id==='s-lightning') initLightning();
  if(id==='s-done') bigConfetti();
}
function goNext(){if(curIdx<SCREEN_ORDER.length-1) showScreen(SCREEN_ORDER[curIdx+1]);}
function goPrev(){if(curIdx>0) showScreen(SCREEN_ORDER[curIdx-1]);}
function goHome(){showScreen('s-home');}
function jumpTo(id){showScreen(id);}

// ═══════════════════════════ PHONICS ═══════════════════════════
function initPhonics(){
  const g=document.getElementById('ph-grid');g.innerHTML='';
  PHONICS.forEach(ph=>{
    const b=document.createElement('button');b.className='ph-tile';
    b.style.background=ph.bg;b.style.color=ph.dark?'#333':'#fff';
    b.innerHTML=`<div class="ph-ltr" style="color:${ph.dark?'#333':'#fff'}">${ph.letter}</div><div class="ph-hint" style="color:${ph.dark?'#555':'rgba(255,255,255,.82)'}">${ph.hint}</div>`;
    b.addEventListener('click',()=>{
      const isG=ph.bg.includes('gradient');
      document.getElementById('zoom-ltr').style.color=isG?'#FFD93D':ph.bg;
      document.getElementById('zoom-ltr').textContent=ph.letter;
      document.getElementById('zoom-ex').textContent=ph.example;
      document.getElementById('zoom-ov').classList.add('show');
    });
    g.appendChild(b);
  });
}
function closeZoom(){document.getElementById('zoom-ov').classList.remove('show');}

// ═══════════════════════════ BLEND ═══════════════════════════
let blendIdx=0,blended=false;
function initBlend(){blendIdx=0;blended=false;buildBDots();renderBlend();}
function buildBDots(){document.getElementById('b-dots').innerHTML=WORDS.map((_,i)=>`<div class="b-dot${i===0?' cur':''}" id="bd-${i}"></div>`).join('');}
function renderBlend(){
  blended=false;const w=WORDS[blendIdx];
  WORDS.forEach((_,i)=>{const d=document.getElementById(`bd-${i}`);if(d)d.className='b-dot'+(i<blendIdx?' done':i===blendIdx?' cur':'');});
  document.getElementById('b-illo').innerHTML=SVG[w.word];
  const bC=document.getElementById('b-con'),bR=document.getElementById('b-res'),bL=document.getElementById('b-lbl'),bFam=document.getElementById('b-fam');
  bC.textContent=w.consonant;bC.style.color=w.color;bC.style.background=w.color+'22';bC.style.opacity='1';bC.style.transform='scale(1)';
  bFam.textContent=FAMILY;bFam.style.color=FAMILY_COLOR;bFam.style.background=FAMILY_BG;bFam.style.opacity='1';bFam.style.transform='scale(1)';
  bR.textContent=w.word;bR.style.color=w.color;bR.className='b-res';
  bL.textContent=`${w.consonant} + ${FAMILY} = ?`;
  document.getElementById('blend-btn').style.display='';
  document.getElementById('blend-skip').textContent=blendIdx<WORDS.length-1?'Next word ▶':'Go to Match!';
}
function doBlend(){
  if(blended)return;blended=true;const w=WORDS[blendIdx];
  const bC=document.getElementById('b-con'),bFam=document.getElementById('b-fam'),bR=document.getElementById('b-res'),bL=document.getElementById('b-lbl');
  bC.style.transition='all .5s cubic-bezier(.175,.885,.32,1.275)';bFam.style.transition='all .5s';
  bC.style.transform='scale(1.22)';bFam.style.transform='scale(1.22)';
  setTimeout(()=>{bR.classList.add('show');bC.style.opacity='.28';bFam.style.opacity='.28';bL.textContent=`${w.consonant} + ${FAMILY} = ${w.word} ✅`;spawnSparkle(window.innerWidth/2,window.innerHeight*.52);},420);
  document.getElementById('blend-btn').style.display='none';
}
function nextBlend(){if(blendIdx<WORDS.length-1){blendIdx++;renderBlend();}else goNext();}

// ═══════════════════════════ MATCH ═══════════════════════════
let matchSel=null,matchDone=0;
function initMatch(){
  matchSel=null;matchDone=0;document.getElementById('match-score').textContent='0 / 6 matched';
  const sP=shuffle([...WORDS]),sW=shuffle([...WORDS]);
  const pE=document.getElementById('match-pics'),wE=document.getElementById('match-words');
  pE.innerHTML='';wE.innerHTML='';
  sP.forEach(w=>{const c=document.createElement('div');c.className='m-pic';c.dataset.word=w.word;c.innerHTML=SVG[w.word];c.addEventListener('click',()=>handleMatchPic(c,w.word));pE.appendChild(c);});
  sW.forEach(w=>{const c=document.createElement('div');c.className='m-word';c.dataset.word=w.word;c.style.color=w.color;c.textContent=w.word;c.addEventListener('click',()=>handleMatchWord(c,w.word));wE.appendChild(c);});
}
function handleMatchPic(card,word){if(card.classList.contains('matched'))return;document.querySelectorAll('.m-pic.selected').forEach(c=>c.classList.remove('selected'));card.classList.add('selected');matchSel={word,el:card};}
function handleMatchWord(card,word){
  if(card.classList.contains('matched'))return;
  if(!matchSel){showToast('Tap a picture first!');return;}
  if(matchSel.word===word){matchSel.el.classList.remove('selected');matchSel.el.classList.add('matched');card.classList.add('matched');matchSel=null;matchDone++;spawnSparkle(card.getBoundingClientRect().left+card.offsetWidth/2,card.getBoundingClientRect().top+card.offsetHeight/2);document.getElementById('match-score').textContent=`${matchDone} / 6 matched`;if(matchDone===6)setTimeout(()=>{bigConfetti();setTimeout(goNext,900);},350);}
  else{[matchSel.el,card].forEach(el=>{el.classList.add('ws');setTimeout(()=>el.classList.remove('ws'),450);});matchSel.el.classList.remove('selected');matchSel=null;showToast('Try again!');}
}

// ═══════════════════════════ SPELL ═══════════════════════════
let spellIdx=0,spellInput=[];
function initSpell(){spellIdx=0;spellInput=[];buildSpDots();renderSpell();}
function buildSpDots(){document.getElementById('sp-dots').innerHTML=WORDS.map((_,i)=>`<div class="sp-dot${i===0?' cur':''}" id="snd-${i}"></div>`).join('');}
function renderSpell(){
  spellInput=[];const w=WORDS[spellIdx];
  WORDS.forEach((_,i)=>{const d=document.getElementById(`snd-${i}`);if(d)d.className='sp-dot'+(i<spellIdx?' done':i===spellIdx?' cur':'');});
  document.getElementById('sp-illo').innerHTML=SVG[w.word];
  document.getElementById('sp-lbl').textContent=w.word.split('').map(()=>'_').join('  ');
  document.getElementById('sp-fb').textContent='';
  document.getElementById('sp-boxes').innerHTML=w.word.split('').map((_,i)=>`<div class="sp-box${i===0?' ab':''}" id="spb-${i}"></div>`).join('');
  const all=shuffle([...w.word.split(''),...shuffle([...DISTRACTORS]).slice(0,3)]);
  document.getElementById('sp-tiles').innerHTML=all.map((l,i)=>`<button class="sp-tile" id="stile-${i}" onclick="tapTile('${l}',${i})">${l.toUpperCase()}</button>`).join('');
}
function tapTile(letter,idx){
  const w=WORDS[spellIdx],pos=spellInput.length;
  if(pos>=w.word.length)return;
  const box=document.getElementById(`spb-${pos}`);
  if(letter===w.word[pos]){
    spellInput.push(letter);box.textContent=letter.toUpperCase();box.classList.remove('ab');box.classList.add('fb','ob');
    document.getElementById(`stile-${idx}`).classList.add('used');
    document.getElementById('sp-lbl').textContent=w.word.split('').map((_,i)=>i<spellInput.length?w.word[i].toUpperCase():'_').join('  ');
    if(spellInput.length<w.word.length)document.getElementById(`spb-${spellInput.length}`)?.classList.add('ab');
    if(spellInput.length===w.word.length){document.getElementById('sp-fb').innerHTML=`<span style="color:var(--green)">✅ ${w.word.toUpperCase()}! Great job!</span>`;spawnSparkle(window.innerWidth/2,window.innerHeight*.44);setTimeout(()=>{if(spellIdx<WORDS.length-1){spellIdx++;buildSpDots();renderSpell();}else goNext();},1500);}
  }else{box.classList.add('eb');showToast('Try again!');setTimeout(()=>box.classList.remove('eb'),480);}
}
function clearSpell(){
  const w=WORDS[spellIdx];spellInput=[];
  w.word.split('').forEach((_,i)=>{const b=document.getElementById(`spb-${i}`);if(b){b.textContent='';b.className='sp-box'+(i===0?' ab':'');}});
  document.querySelectorAll('.sp-tile').forEach(t=>t.classList.remove('used'));
  document.getElementById('sp-lbl').textContent=w.word.split('').map(()=>'_').join('  ');
  document.getElementById('sp-fb').textContent='';
}

// ═══════════════════════════ FLASHCARD ═══════════════════════════
let flashIdx=0,flashFlipped=false,flashMode='pic'; // 'pic' = picture first, 'word' = word first

function initFlash(){
  flashIdx=0;flashFlipped=false;
  // reset toggle to pic mode visually
  setFlashMode(flashMode,true);
  buildFlDots();renderFlash();
}

function setFlashMode(mode, silent){
  flashMode=mode;
  document.getElementById('fl-btn-pic').classList.toggle('active-mode',mode==='pic');
  document.getElementById('fl-btn-word').classList.toggle('active-mode',mode==='word');
  if(!silent){flashIdx=0;flashFlipped=false;buildFlDots();renderFlash();}
}

function buildFlDots(){
  document.getElementById('fl-dots').innerHTML=WORDS.map((_,i)=>
    `<div class="fl-dot${i===0?' cur':''}" id="fld-${i}"></div>`
  ).join('');
}

function renderFlash(){
  flashFlipped=false;
  const w=WORDS[flashIdx];
  WORDS.forEach((_,i)=>{const d=document.getElementById(`fld-${i}`);if(d)d.className='fl-dot'+(i<flashIdx?' done':i===flashIdx?' cur':'');});
  document.getElementById('fc-inner').classList.remove('flipped');
  document.getElementById('fl-count').textContent=`${flashIdx+1} / ${WORDS.length}`;

  const picHTML=`<div class="fc-pic"><div style="width:clamp(90px,18vw,155px);height:clamp(90px,18vw,155px);display:flex;align-items:center;justify-content:center">${SVG[w.word]}</div></div>
    <div class="fc-tap">👆 Tap to flip</div>`;

  const wordHTML=`<div class="fc-word" style="color:${w.color}">${w.word}</div>
    <div class="fc-word-hint" style="color:${w.color}">${w.consonant.toUpperCase()} + ${FAMILY.toUpperCase()}</div>
    <div class="fc-tap">👆 Tap to flip</div>`;

  if(flashMode==='pic'){
    // Front = picture, Back = word
    document.getElementById('fc-front').innerHTML=picHTML;
    document.getElementById('fc-back').innerHTML=wordHTML.replace('Tap to flip','Tap for next ▶');
  } else {
    // Front = word, Back = picture
    document.getElementById('fc-front').innerHTML=wordHTML;
    document.getElementById('fc-back').innerHTML=picHTML.replace('Tap to flip','Tap for next ▶');
  }
}

function flipCard(){
  flashFlipped=!flashFlipped;
  document.getElementById('fc-inner').classList.toggle('flipped',flashFlipped);
  if(flashFlipped) spawnSparkle(window.innerWidth/2, window.innerHeight*.42);
}

function flashNext(){
  if(flashIdx<WORDS.length-1){flashIdx++;renderFlash();}
  else{bigConfetti();setTimeout(goNext,800);}
}
function flashPrev(){if(flashIdx>0){flashIdx--;renderFlash();}}

// ═══════════════════════════ LIGHTNING ROUND ═══════════════════════════
let lrScore=0,lrQ=0,lrAnswered=false,lrQueue=[],lrTimerInterval=null,lrTimeLeft=0,lrTotalTime=7;
function initLightning(){
  lrScore=0;lrQ=0;lrAnswered=false;
  lrQueue=shuffle([...WORDS]);
  document.getElementById('lr-score').textContent='0';
  document.getElementById('lr-feedback').textContent='';
  nextLR();
}
function nextLR(){
  if(lrQ>=WORDS.length){endLR();return;}
  lrAnswered=false;
  const w=lrQueue[lrQ];
  document.getElementById('lr-qnum').textContent=`Q ${lrQ+1}/${WORDS.length}`;
  document.getElementById('lr-illo').innerHTML=SVG[w.word];
  document.getElementById('lr-feedback').textContent='';
  // choices: correct + 2 wrong
  const wrongs=shuffle(WORDS.filter(x=>x.word!==w.word)).slice(0,2);
  const choices=shuffle([w,...wrongs]);
  document.getElementById('lr-choices').innerHTML=choices.map(c=>`
    <button class="lr-btn" onclick="answerLR('${c.word}','${w.word}')">${c.word}</button>
  `).join('');
  // timer
  clearInterval(lrTimerInterval);
  lrTimeLeft=lrTotalTime;
  updateTimerBar();
  lrTimerInterval=setInterval(()=>{
    lrTimeLeft-=0.1;
    if(lrTimeLeft<=0){clearInterval(lrTimerInterval);if(!lrAnswered)timeOutLR(w.word);}
    else updateTimerBar();
  },100);
}
function updateTimerBar(){
  const pct=Math.max(0,lrTimeLeft/lrTotalTime*100);
  document.getElementById('lr-bar').style.width=pct+'%';
}
function answerLR(chosen,correct){
  if(lrAnswered)return;lrAnswered=true;clearInterval(lrTimerInterval);
  const btns=document.querySelectorAll('.lr-btn');
  btns.forEach(b=>{if(b.textContent===correct)b.classList.add('correct-lr');else if(b.textContent===chosen&&chosen!==correct)b.classList.add('wrong-lr');});
  if(chosen===correct){lrScore++;document.getElementById('lr-score').textContent=lrScore;document.getElementById('lr-feedback').textContent='✅ Yes!';spawnSparkle(window.innerWidth/2,window.innerHeight*.6);}
  else{document.getElementById('lr-feedback').textContent='❌ That was: '+correct;}
  lrQ++;setTimeout(nextLR,1100);
}
function timeOutLR(correct){
  lrAnswered=true;
  document.getElementById('lr-feedback').textContent='⏰ Too slow! It was: '+correct;
  document.querySelectorAll('.lr-btn').forEach(b=>{if(b.textContent===correct)b.classList.add('correct-lr');});
  lrQ++;setTimeout(nextLR,1200);
}
function endLR(){
  clearInterval(lrTimerInterval);
  const pct=Math.round(lrScore/WORDS.length*100);
  const msg=pct===100?'🏆 Perfect score!':pct>=67?'🌟 Great job!':'💪 Keep practising!';
  document.getElementById('lr-card').innerHTML=`
    <div style="display:flex;flex-direction:column;align-items:center;gap:12px;text-align:center;width:100%">
      <div style="font-size:clamp(2.5rem,8vw,5rem);font-weight:900;color:var(--text)">${lrScore} / ${WORDS.length}</div>
      <div style="font-size:clamp(1rem,2.8vw,1.6rem);color:var(--muted)">${msg}</div>
      <button class="lr-play-again" onclick="initLightning()" style="border:none;border-radius:50px;padding:12px 34px;font-family:'Nunito',sans-serif;font-weight:900;font-size:clamp(.95rem,2.3vw,1.35rem);color:#fff;background:linear-gradient(135deg,#FF6B6B,#FF8E53);box-shadow:0 6px 0 #c9472e;cursor:pointer;">Play again ⚡</button>
      <button onclick="goNext()" style="border:none;background:none;font-family:'Nunito',sans-serif;font-weight:800;font-size:.9rem;color:var(--muted);cursor:pointer;text-decoration:underline;margin-top:4px;">Finish →</button>
    </div>`;
  document.getElementById('lr-feedback').textContent='';
  if(pct===100)bigConfetti();
}

// ═══════════════════════════ EFFECTS ═══════════════════════════
const SPARKS=['✨','⭐','🌟','💫','🎉'];
function spawnSparkle(x,y){for(let i=0;i<4;i++){const el=document.createElement('div');el.className='sparkle';el.textContent=SPARKS[Math.floor(Math.random()*SPARKS.length)];el.style.cssText=`left:${x-18+(Math.random()-.5)*65}px;top:${y-18+(Math.random()-.5)*48}px;animation-delay:${i*.1}s`;document.body.appendChild(el);setTimeout(()=>el.remove(),1000);}}
function bigConfetti(){const cols=['#E63946','#F5C800','#2BAE66','#1A78C2','#FB5607','#8338EC','#fff','#E91E8C'];for(let i=0;i<38;i++){const el=document.createElement('div');el.className='conf-p';el.style.cssText=`left:${Math.random()*100}vw;top:${Math.random()*28}vh;background:${cols[i%cols.length]};animation-delay:${Math.random()*.55}s;transform:rotate(${Math.random()*360}deg)`;document.body.appendChild(el);setTimeout(()=>el.remove(),2100);}}
function showToast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),1400);}
function shuffle(a){return a.sort(()=>Math.random()-.5);}

showScreen('s-home');
</script>
